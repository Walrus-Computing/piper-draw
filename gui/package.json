{
  "name": "piper-draw-gui",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.1.3.6",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "vite",
    "dev:backend": "cd .. && uv run uvicorn server:app --reload --port ${BACKEND_PORT:-8000}",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --require ./scripts/vitest-crypto-shim.cjs ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node --require ./scripts/vitest-crypto-shim.cjs ./node_modules/vitest/vitest.mjs",
    "slop:diff": "node scripts/slop-diff.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.184.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@react-three/test-renderer": "^9.1.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.0",
    "rollup-plugin-license": "^3.7.1",
    "slop-scan": "^0.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
